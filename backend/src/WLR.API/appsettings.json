{
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Database=wlr_db;Username=wlr_user;Password=wlr_secure_password;",
    "Redis": "redis:6379"
  },
  "JwtSettings": {
    "SecretKey": "WLR_SUPER_SECRET_KEY_CHANGE_IN_PRODUCTION_MIN_32_CHARS",
    "Issuer": "WaterLevelRecognizer",
    "Audience": "WLRUsers",
    "AccessTokenExpiryHours": 1,
    "RefreshTokenExpiryDays": 30
  },
  "SmsSettings": {
    "Provider": "Console"
  },
  "AllowedOrigins": [
    "http://localhost:5173",
    "https://wlr.yourdomain.com"
  ],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  }
}
