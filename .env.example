# === WaterLevelRecognizer Environment Configuration ===

# Database
POSTGRES_DB=wlr_db
POSTGRES_USER=wlr_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_CONNECTION_STRING=Host=postgres;Database=wlr_db;Username=wlr_user;Password=CHANGE_THIS_STRONG_PASSWORD;

# Redis
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_CONNECTION_STRING=redis:6379,password=CHANGE_THIS_REDIS_PASSWORD

# JWT
JWT_SECRET_KEY=CHANGE_THIS_TO_A_STRONG_SECRET_KEY_AT_LEAST_32_CHARACTERS
JWT_ISSUER=WaterLevelRecognizer
JWT_AUDIENCE=WLRUsers

# SMS Provider (Console | Twilio | AWSSNS)
SMS_PROVIDER=Console

# Frontend
VITE_API_URL=http://localhost:8080
VITE_SIGNALR_URL=http://localhost:8080/hubs

# App
APP_ENV=production
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
